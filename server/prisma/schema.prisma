generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  firstName String   @default("")
  gender    String   @default("")
  createdAt DateTime @default(now())
  rounds    Round[]
}

model Round {
  id               Int      @id @default(autoincrement())
  course           String
  courseExternalId Int?
  courseRating     Float?
  slopeRating     Int?
  teeName          String?
  date             DateTime @default(now())
  status           String   @default("PUBLISHED")
  holes            Hole[]
  user             User?    @relation(fields: [userId], references: [id])
  userId           Int?
  createdAt        DateTime @default(now())
}

model Hole {
  id      Int    @id @default(autoincrement())
  number  Int
  par     Int
  shots   Shot[]
  round   Round  @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roundId Int

  @@unique([roundId, number])
}

model Shot {
  id            Int   @id @default(autoincrement())
  hole          Hole  @relation(fields: [holeId], references: [id], onDelete: Cascade)
  holeId        Int
  shotNumber    Int
  startLie      String
  startDistance Float
  endLie        String
  endDistance   Float

  @@unique([holeId, shotNumber])
}
